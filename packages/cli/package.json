    "requirements",
    "engineering",
    "cli",
    "requirements-management",
    "systems-engineering",
    "traceability",
    "sysml",
    "mbse",
    "uht"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/airgen-studio/airgen.git",
    "directory": "packages/cli"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
