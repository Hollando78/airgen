{
  "name": "airgen-cli",
  "version": "0.3.1",
  "description": "AIRGen CLI — requirements engineering from the command line",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "airgen": "dist/index.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
