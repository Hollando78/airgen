# Dependencies
node_modules
.pnpm-store

# Builds
dist
build

# Env
.env
.env.*
env/development.env

# Allow tracked environment templates
!/env/**/*.example
!/backend/.env.*.example
!/frontend/.env.*.example

# Logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Misc
.DS_Store
.idea
.vscode

# Workspace - Track structure but exclude large/temp files
# Track workspace directory structure and important data files
!workspace/
!workspace/**/*.md
!workspace/**/*.json
!workspace/**/*.yaml
!workspace/**/*.yml
!workspace/**/requirements/
!workspace/**/requirements/**/*.md
!workspace/**/documents/
!workspace/**/documents/**/*.md

# Exclude temp/cache files in workspace
workspace/**/*.tmp
workspace/**/*.cache
workspace/**/*.log
workspace/**/.DS_Store

# Keep gitkeep files
!workspace/.gitkeep
!workspace/**/.gitkeep

# Credentials and sensitive files
**/login.json
**/*credentials*.json
**/*secret*.json
**/*password*.txt

# Testing
test-results/
playwright-report/
playwright/.cache/
*.trace.zip

