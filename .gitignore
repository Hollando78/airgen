# Dependencies
node_modules
.pnpm-store

# Builds
dist
build

# Env
.env
.env.*
env/development.env

# Allow tracked environment templates
!/env/**/*.example
!/backend/.env.*.example
!/frontend/.env.*.example

# Logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Misc
.DS_Store
.idea
.vscode

# Workspace - Track structure but exclude large/temp files
# Track workspace directory structure and important data files
!workspace/
!workspace/**/*.md
!workspace/**/*.json
!workspace/**/*.yaml
!workspace/**/*.yml
!workspace/**/requirements/
!workspace/**/requirements/**/*.md
!workspace/**/documents/
!workspace/**/documents/**/*.md

# Exclude temp/cache files in workspace
workspace/**/*.tmp
workspace/**/*.cache
workspace/**/*.log
workspace/**/.DS_Store

# Keep gitkeep files
!workspace/.gitkeep
!workspace/**/.gitkeep

# Credentials and sensitive files
**/login.json
**/*credentials*.json
**/*secret*.json
**/*password*.txt

# Docker secrets directory (NEVER COMMIT!)
/root/airgen-secrets/
airgen-secrets/

# Testing
test-results/
playwright-report/
playwright/.cache/
*.trace.zip
coverage/

# Backups
backups/

# Temporary debug/check scripts
backend/check-*.ts
backend/check-*.js
backend/check-*.sh
backend/test-*.ts
backend/test-*.js
backend/verify-*.ts
backend/create-test-data.ts
backend/delete-test-data.ts
backend/fix-*.ts
backend/cleanup-*.ts
backend/orphan-*.ts
backend/reset-password.ts
backend/restore-*.ts
backend/src/config.js
backend/src/services/graph/driver.js

# Workspace temp/undefined directories
workspace/undefined/
workspace/info-*/

# Media files
*.MOV
*.mov
*.mp4

