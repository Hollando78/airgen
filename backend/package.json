{
  "name": "@airgen/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run src/services/__tests__/drafts.test.ts src/services/__tests__/llm.test.ts --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "backfill:content": "tsx src/scripts/backfill-content-blocks.ts"
  },
  "dependencies": {
    "@airgen/req-qa": "file:../packages/req-qa",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@neo4j/cypher-builder": "^2.8.0",
    "@types/pg": "^8.15.5",
    "argon2": "^0.44.0",
    "canvas": "^3.2.0",
    "dotenv": "^17.2.2",
    "fastify": "^5.6.1",
    "neo4j-driver": "^5.25.0",
    "nodemailer": "^7.0.9",
    "openai": "^4.57.0",
    "otplib": "^12.0.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.149",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "redis": "^5.8.2",
    "sharp": "^0.34.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@sentry/node": "^10.17.0",
    "@sentry/profiling-node": "^10.17.0",
    "@testcontainers/neo4j": "^10.13.2",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^7.0.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.0",
    "eslint": "^9.36.0",
    "eslint-plugin-node": "^11.1.0",
    "otpauth": "^9.4.1",
    "pino-pretty": "^13.1.1",
    "prom-client": "^15.1.3",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^1.6.0"
  }
}
