# Backend service production defaults (loaded when API_ENV=production)
API_HOST=0.0.0.0
API_PORT=8787
API_JWT_SECRET=replace_with_secure_secret
API_ENV=production
WORKSPACE_ROOT=/workspace

# Neo4j connection for production graph DB
GRAPH_URL=bolt://neo4j:7687
GRAPH_USERNAME=neo4j
GRAPH_PASSWORD=change_this_strong_password
GRAPH_DATABASE=neo4j
GRAPH_ENCRYPTED=false

# LLM provider credentials (required for AI features)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_TEMPERATURE=0.2

# Email configuration (required for password reset, email verification)
EMAIL_FROM=info@airgen.studio
EMAIL_SYSTEM_BCC=info@airgen.studio
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# CORS configuration (required in production)
CORS_ORIGINS=https://airgen.studio

# App URL for email links
APP_URL=https://airgen.studio

# Rate limiting (optional, defaults shown)
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW=60000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=300000
RATE_LIMIT_LLM_MAX=20
RATE_LIMIT_LLM_WINDOW=3600000

# Feature flags
ENABLE_ADMIN_ROUTES=false
