# Git LFS Configuration for AirGen
# Install Git LFS: apt-get install git-lfs && git lfs install
# Track large workspace files with LFS for efficient versioning

# Large binary files (if any added to workspace)
*.pdf filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Database exports (if committed)
*.sql filter=lfs diff=lfs merge=lfs -text
*.dump filter=lfs diff=lfs merge=lfs -text

# Text files should have unix line endings
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# Ensure shell scripts are executable
*.sh filter=lfs diff=lfs merge=lfs -text
