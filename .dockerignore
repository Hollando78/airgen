# AIRGen Docker Ignore File
# Excludes unnecessary files from Docker build context
# This significantly speeds up builds by reducing context size

# Version control
.git
.gitignore
.gitattributes

# Dependencies (will be installed in container)
node_modules
**/node_modules
.pnpm-store

# Build artifacts
dist
build
.next
.cache
*.log
*.log.*

# User data and workspace (mounted at runtime)
workspace/
workspace/*
backups/
backups/*

# Development files
.env
.env.local
.env.development
.env.test
*.local

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Test files
coverage
*.test.ts
*.test.js
*.spec.ts
*.spec.js
__tests__
**/__tests__

# Documentation
README.md
docs/
*.md
!package.json

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Temporary files
tmp/
temp/
*.tmp

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
Thumbs.db
.DS_Store

# Docker files (don't need to copy these into the build)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Linter and formatter configs (not needed at runtime)
.eslintrc*
.prettierrc*
.editorconfig

# TypeScript incremental build info
*.tsbuildinfo

# Production deployment artifacts
letsencrypt/
traefik/

# Secrets
**/secrets/
**/*_secret*
**/*_password*
*.pem
*.key
*.crt

# Database files (handled by volumes)
*.db
*.sqlite
*.sqlite3

# Large media files (should be in CDN/S3)
*.mp4
*.mov
*.avi
*.mkv
*.wmv
