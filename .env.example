# ===========================================
# AIRGen Environment Configuration Template
# ===========================================
# Copy this file to .env.local and fill in your values
# For production, use .env.production

# ===========================================
# ENVIRONMENT
# ===========================================
# Options: development, staging, production, test
API_ENV=development
NODE_ENV=development

# ===========================================
# APPLICATION URLS
# ===========================================
# Frontend application URL (used for email links)
APP_URL=http://localhost:5173
# Backend API URL (used for CORS validation)
API_URL=http://localhost:8787

# ===========================================
# SERVER CONFIGURATION
# ===========================================
API_HOST=0.0.0.0
API_PORT=8787

# ===========================================
# SECURITY - REQUIRED IN PRODUCTION
# ===========================================
# JWT secret for signing tokens (REQUIRED in production)
# Generate with: openssl rand -base64 32
API_JWT_SECRET=dev_secret_DO_NOT_USE_IN_PROD

# CORS allowed origins (comma-separated)
# In production, list your frontend domains
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# GRAPH DATABASE (Neo4j) - REQUIRED
# ===========================================
GRAPH_URL=bolt://neo4j:7687
GRAPH_USERNAME=neo4j
GRAPH_PASSWORD=airgen-graph
GRAPH_DATABASE=neo4j
GRAPH_ENCRYPTED=false

# ===========================================
# DATA STORAGE
# ===========================================
WORKSPACE_ROOT=./workspace
API_DEFAULT_TENANT=default

# ===========================================
# RATE LIMITING
# ===========================================
# Global rate limit (requests per time window)
RATE_LIMIT_GLOBAL_MAX=500
RATE_LIMIT_GLOBAL_WINDOW=60000

# Auth endpoint rate limit (login, register, etc.)
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW=300000

# ===========================================
# EMAIL CONFIGURATION (optional)
# ===========================================
# If not set, emails will be logged to console
EMAIL_FROM=noreply@localhost
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ===========================================
# TWO-FACTOR AUTHENTICATION (2FA)
# ===========================================
# Encryption key for TOTP secrets (defaults to JWT_SECRET)
# Generate with: openssl rand -base64 32
TWOFA_ENCRYPTION_KEY=
# Issuer name shown in authenticator apps
TWOFA_ISSUER=AIRGen

# ===========================================
# AI/LLM CONFIGURATION (optional)
# ===========================================
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_TEMPERATURE=0.2

# Drafting service limits
AI_DRAFT_LIMIT=5
AI_DRAFT_CACHE_TTL=900

# Legacy OpenAI configuration (for backward compatibility)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# INFRASTRUCTURE (Docker Compose)
# ===========================================
POSTGRES_USER=airgen
POSTGRES_PASSWORD=airgen
POSTGRES_DB=airgen
POSTGRES_PORT=5432
REDIS_PORT=6379
TRAEFIK_HTTP_PORT=80
